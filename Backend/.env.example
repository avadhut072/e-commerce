# Rename this file to .env and fill in the values before running the backend.

# MongoDB connection
MONGO_URL=mongodb+srv://<username>:<password>@cluster0.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT (if used elsewhere)
JWT_SECRET=your_jwt_secret_here

# Razorpay API credentials (required for payment gateway)
RAZORPAY_API_KEY=your_razorpay_key_id_here
RAZORPAY_API_SECRET=your_razorpay_key_secret_here

# Email service (used for sending order confirmation)
EMAIL=your_email@example.com
EMAIL_PASSWORD=your_email_password_here
